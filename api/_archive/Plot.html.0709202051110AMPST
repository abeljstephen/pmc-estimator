    function validateTargetInput() {
        var input = document.getElementById('target-value-input');
        var message = document.getElementById('target-value-message');
        var optimizeButton = document.getElementById('optimize-button');
        var task = document.getElementById('task-select').value;

        if (!task || !tasks[task]) {
            message.textContent = 'Please select a valid task.';
            optimizeButton.disabled = true;
            return false;
        }

        if (!input.value) {
            message.textContent = 'Please enter a target value.';
            optimizeButton.disabled = true;
            return false;
        }

        var value = parseFloat(input.value);
        var min = tasks[task].optimistic;
        var max = tasks[task].pessimistic;

        if (isNaN(value) || value < min || value > max) {
            message.textContent = 'Value must be between ' + min + ' and ' + max + '.';
            optimizeButton.disabled = true;
            return false;
        }

        message.textContent = '';
        optimizeButton.disabled = false;
        window.sliderState.targetValue = value.toString();
        return true;
    }

