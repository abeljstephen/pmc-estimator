            '<tr><td>Adjusted Probability</td><td>' + adjProb.toFixed(1) + '%</td><td>Adjusted</td><td>Optimized CDF</td></tr>' +
            '<tr><td>Mean Shift</td><td>' + (targetProbabilityData.decisionOptimizerMetrics?.value?.meanShift || 0).toFixed(2) + '</td><td>Mean shift</td><td>0.2 × σ × (-BF - SF + 0.5 × (1 - SC))</td></tr>' +
            '<tr><td>Variance Scale</td><td>' + (targetProbabilityData.decisionOptimizerMetrics?.value?.varianceScale || 1).toFixed(2) + '</td><td>Variance factor</td><td>1 + 2.0 × (1 - SC)</td></tr>' +
            '<tr><td>Skew Adjustment</td><td>' + (targetProbabilityData.decisionOptimizerMetrics?.value?.skewAdjustment || 0).toFixed(2) + '</td><td>Skew change</td><td>-0.05 × RT + 0.2 × (1 - SC)</td></tr>' +
            '</tbody>';

        var reportDiv = document.getElementById('target-report');
        reportDiv.innerHTML = '<div class="analysis-report">' +
            '<h4>Key Concepts</h4>' +
            '<ul>' +
            '<li><strong>Original Distribution</strong>: Median = <span class="dynamic">' + (targetProbabilityData.decisionOptimizerMetrics?.value?.originalMedian || tasks[document.getElementById('task-select').value]?.mostLikely || 2400).toFixed(2) + '</span>, Mean = <span class="dynamic">' + (targetProbabilityData.decisionOptimizerMetrics?.value?.originalMean || tasks[document.getElementById('task-select').value]?.mostLikely || 2400).toFixed(2) + '</span>, Std Dev = <span class="dynamic">' + (targetProbabilityData.decisionOptimizerMetrics?.value?.originalStdDev || 200).toFixed(2) + '</span></li>' +
            '<li><strong>Adjusted Distribution</strong>: Based on slider inputs.</li>' +
            '<li><strong>Probability</strong>: Chance of meeting target.</li>' +
            '</ul>' +
            '<h4>Transformation Formulas</h4>' +
            '<ul>' +
            '<li>Mean Shift: <code>' + (targetProbabilityData.decisionOptimizerMetrics?.value?.meanShift || 0).toFixed(2) + '</code></li>' +
            '<li>Variance Scaling: <code>' + (targetProbabilityData.decisionOptimizerMetrics?.value?.varianceScale || 1).toFixed(2) + '</code></li>' +
            '<li>Skew Adjustment: <code>' + (targetProbabilityData.decisionOptimizerMetrics?.value?.skewAdjustment || 0).toFixed(2) + '</code></li>' +
            '<li>New Mean: <code>' + (targetProbabilityData.decisionOptimizerMetrics?.value?.optimizedMean || tasks[document.getElementById('task-select').value]?.mostLikely || 2400).toFixed(2) + '</code></li>' +
            '<li>New Std Dev: <code>' + (targetProbabilityData.decisionOptimizerMetrics?.value?.optimizedStdDev || 200).toFixed(2) + '</code></li>' +
            '</ul>' +
            '<h4>Summary</h4>' +
            '<p>Original probability: <span class="dynamic">' + origProb.toFixed(1) + '%</span> for <span class="dynamic">' + targetValue.toFixed(2) + '</span>. Adjusted probability: <span class="dynamic">' + adjProb.toFixed(1) + '%</span> with current settings.</p>' +
            '</div>';
    }

    function populateCombinationTable(page) {
        if (typeof page === 'undefined') page = 1;
        var combTable = document.getElementById('combination-table-body');
        var filterValue = document.getElementById('probability-filter').value;
        var targetValue = parseFloat(document.getElementById('target-value-input').value) || tasks[document.getElementById('task-select').value]?.mostLikely || 2500;
        var mode = document.getElementById('mode-select').value;

        var combinations = [];
        if (targetProbabilityData && targetProbabilityData.decisionOptimizerMetrics && targetProbabilityData.decisionOptimizerMetrics.value) {
            var baseMean = targetProbabilityData.decisionOptimizerMetrics.value.originalMean || tasks[document.getElementById('task-select').value]?.mostLikely || 2500;
            var baseStdDev = targetProbabilityData.decisionOptimizerMetrics.value.originalStdDev || 200;
            for (var bf = 0; bf <= 100; bf += 10) {
                for (var sf = 0; sf <= 100; sf += 10) {
                    for (var sc = 0; sc <= 100; sc += 10) {
                        for (var rt = 0; rt <= 100; rt += 10) {
                            var meanShift = 0.2 * baseStdDev * (-bf / 100 - sf / 100 + 0.5 * (1 - sc / 100));
                            var varianceScale = 1 + 2.0 * (1 - sc / 100);
                            var skewAdjustment = -0.05 * (rt / 100) + 0.2 * (1 - sc / 100);
                            var newMean = baseMean + meanShift;
                            var newStdDev = baseStdDev * Math.sqrt(varianceScale);
                            var zScore = (targetValue - newMean) / newStdDev;
                            var prob = (1 - 0.5 * Math.exp(-0.717 * zScore - 0.416 * zScore * zScore)) * 100; // Approximation
                            if (prob >= 0 && prob <= 100) {
                                combinations.push({ bf: bf, sf: sf, sc: sc, rt: rt, prob: prob });
                            }
                        }
                    }
                }
            }
        }

        // Filter combinations based on selected option
        var filteredCombinations = combinations;
        if (filterValue === 'above50') {
            filteredCombinations = combinations.filter(c => c.prob > 50);
        } else if (filterValue === 'above75') {
            filteredCombinations = combinations.filter(c => c.prob > 75);
        } else if (filterValue === 'below50') {
            filteredCombinations = combinations.filter(c => c.prob < 50);
        } else if (filterValue === 'current') {
            filteredCombinations = combinations.filter(c => c.bf === parseInt(window.sliderState.budgetFlexibility) && c.sf === parseInt(window.sliderState.scheduleFlexibility) && c.sc === parseInt(window.sliderState.scopeCertainty) && c.rt === parseInt(window.sliderState.riskTolerance));
        } else if (filterValue === 'optimized' && targetProbabilityData?.optimalCombination?.value) {
            filteredCombinations = combinations.filter(c => c.bf === targetProbabilityData.optimalCombination.value.budgetFlexibility && c.sf === targetProbabilityData.optimalCombination.value.scheduleFlexibility && c.sc === targetProbabilityData.optimalCombination.value.scopeCertainty && c.rt === targetProbabilityData.optimalCombination.value.riskTolerance);
        }

        var pageSize = 50;
        var totalPages = Math.ceil(filteredCombinations.length / pageSize);
        var currentPage = Math.min(Math.max(1, page), totalPages);
        var start = (currentPage - 1) * pageSize;
        var end = start + pageSize;
        var pageCombinations = filteredCombinations.slice(start, end);

        combTable.innerHTML = '<tr><td colspan="8">Showing ' + filterValue.charAt(0).toUpperCase() + filterValue.slice(1).replace(/([A-Z])/g, ' $1') + ' combinations impact on probability.</td></tr>' +
            '<tr style="background: #2c5282; color: white;">' +
            '<th>Combination</th>' +
            '<th>Budget Flexibility (%)</th>' +
            '<th>Schedule Flexibility (%)</th>' +
            '<th>Scope Certainty (%)</th>' +
            '<th>Risk Tolerance (%)</th>' +
            '<th>Probability (%)</th>' +
            '<th>Scenario Summary</th>' +
            '<th>Expected Outcome</th>' +
            '</tr>' +
            pageCombinations.map(function(c) {
                return '<tr>' +
                    '<td>' + (filterValue === 'current' ? 'Current' : filterValue === 'optimized' ? 'Optimized' : 'Combo') + '</td>' +
                    '<td>' + c.bf + '%</td>' +
                    '<td>' + c.sf + '%</td>' +
                    '<td>' + c.sc + '%</td>' +
                    '<td>' + c.rt + '%</td>' +
                    '<td>' + c.prob.toFixed(3) + ' (' + c.prob.toFixed(1) + '%)' + '</td>' +
                    '<td>' + (c.bf === c.sf && c.sf === c.sc && c.sc === c.rt ? 'Balanced' : 'Unbalanced') + '</td>' +
                    '<td>' + (c.prob.toFixed(1) + '% probability with ' + (100 - c.prob).toFixed(1) + '% risk') + '</td>' +
                    '</tr>';
            }).join('');

        document.getElementById('page-info').textContent = 'Page ' + currentPage + ' of ' + totalPages;
        document.getElementById('prev-page').disabled = currentPage === 1;
        document.getElementById('next-page').disabled = currentPage === totalPages;

        document.getElementById('prev-page').onclick = function() { populateCombinationTable(currentPage - 1); };
        document.getElementById('next-page').onclick = function() { populateCombinationTable(currentPage + 1); };
        document.getElementById('probability-filter').onchange = function() { populateCombinationTable(1); }; // Reset to page 1 on filter change
    }

    function updateResultsSummary() {
        var targetValue = parseFloat(document.getElementById('target-value-input').value) || tasks[document.getElementById('task-select').value]?.mostLikely || 2500;
        var origProb = targetProbabilityData?.targetProbabilityOriginalCdf?.value?.find(p => Math.abs(p.x - targetValue) < 1)?.y * 100 || 50;
        var adjProb = targetProbabilityData?.targetProbabilityAdjustedCdf?.value?.find(p => Math.abs(p.x - targetValue) < 1)?.y * 100 || 50;
        var optimalValue = targetProbabilityData?.optimalCombination?.value?.optimizedTarget || targetValue;
        var optimalProb = targetProbabilityData?.targetProbabilityAdjustedCdf?.value?.find(p => Math.abs(p.x - optimalValue) < 1)?.y * 100 || adjProb;
        var optimalSliders = targetProbabilityData?.optimalCombination?.value || {
            budgetFlexibility: parseFloat(window.sliderState.budgetFlexibility),
            scheduleFlexibility: parseFloat(window.sliderState.scheduleFlexibility),
            scopeCertainty: parseFloat(window.sliderState.scopeCertainty),
            riskTolerance: parseFloat(window.sliderState.riskTolerance)
        };

        var resultsText = 'Results Summary: ' +
            'Original: Value ' + targetValue.toFixed(2) + ' has ' + origProb.toFixed(1) + '% confidence, ' +
            'Adjusted: Value ' + targetValue.toFixed(2) + ' has ' + adjProb.toFixed(1) + '% confidence, ' +
            'Optimal: Value ' + optimalValue.toFixed(2) + ' has ' + optimalProb.toFixed(1) + '% confidence, ' +
            'Optimal Sliders: Budget Flexibility ' + optimalSliders.budgetFlexibility.toFixed(1) + '%, ' +
            'Schedule Flexibility ' + optimalSliders.scheduleFlexibility.toFixed(1) + '%, ' +
            'Scope Certainty ' + optimalSliders.scopeCertainty.toFixed(1) + '%, ' +
            'Risk Tolerance ' + optimalSliders.riskTolerance.toFixed(1) + '%.';
        document.getElementById('results-text').textContent = resultsText;
    }

    var backToTopButton = document.getElementById('back-to-top');
    window.addEventListener('scroll', function() {
        backToTopButton.style.display = window.scrollY > 300 ? 'block' : 'none';
    }, { passive: true });
    backToTopButton.addEventListener('click', function() { window.scrollTo({ top: 0, behavior: 'smooth' }); }, { passive: true });
</script></body>
