    function optimize() {
        var mode = document.getElementById('mode-select').value;
        var task = document.getElementById('task-select').value;
        var targetValue = parseFloat(document.getElementById('target-value-input').value);
        var confidence = parseInt(document.getElementById('confidence-level-input').value);
        var optimizeButton = document.getElementById('optimize-button');

        if (!tasks[task] || !validateInputs()) return;

        optimizeButton.disabled = true;
        document.getElementById('loading-overlay').textContent = 'Optimizing...';
        document.getElementById('loading-overlay').style.display = 'flex';

        var payload = {
            task: {
                task: task,
                optimistic: tasks[task].optimistic,
                mostLikely: tasks[task].mostLikely,
                pessimistic: tasks[task].pessimistic
            },
            sliderValues: {
                budgetFlexibility: parseFloat(window.sliderState.budgetFlexibility) || 50,
                scheduleFlexibility: parseFloat(window.sliderState.scheduleFlexibility) || 50,
                scopeCertainty: parseFloat(window.sliderState.scopeCertainty) || 50,
                riskTolerance: parseFloat(window.sliderState.riskTolerance) || 50
            },
            optimizeFor: mode,
        };
        if (mode === 'target') {
            payload.targetValue = targetValue;
        } else {
            payload.confidenceLevel = confidence;
        }

        fetch(API_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        })
        .then(function(response) {
            if (!response.ok) {
                console.error('HTTP Error:', response.status, 'Response Text:', response.text());
                throw new Error('HTTP error! Status: ' + response.status);
            }
            return response.json();
        })
        .then(function(data) {
            window.sliderState.budgetFlexibility = data.optimalCombination.value.budgetFlexibility.toString();
            window.sliderState.scheduleFlexibility = data.optimalCombination.value.scheduleFlexibility.toString();
            window.sliderState.scopeCertainty = data.optimalCombination.value.scopeCertainty.toString();
            window.sliderState.riskTolerance = data.optimalCombination.value.riskTolerance.toString();
            restoreSliders();
            fetchTargetProbabilityData(function() {
                drawAllPlots();
                updateHeaders();
                updateResultsSummary();
            });
        })
        .catch(function(error) {
            console.error('Optimization Error Details:', error);
            document.getElementById('loading-overlay').textContent = 'Optimization failed. Check API configuration or Google Cloud Function logs.';
            setTimeout(function() {
                document.getElementById('loading-overlay').style.display = 'none';
                document.getElementById('loading-overlay').textContent = 'Loading, please wait...';
                optimizeButton.disabled = false;
            }, 2000);
        })
        .finally(function() {
            if (!document.getElementById('loading-overlay').textContent.includes('failed')) {
                document.getElementById('loading-overlay').style.display = 'none';
                optimizeButton.disabled = false;
            }
        });
    }

