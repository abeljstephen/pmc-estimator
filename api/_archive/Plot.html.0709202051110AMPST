    function setupSliderListeners() {
        var sliders = ['targetBudgetFlexibility', 'targetScheduleFlexibility', 'targetScopeCertainty', 'targetRiskTolerance'];
        var debounce = function(func, wait) {
            var timeout;
            return function () {
                clearTimeout(timeout);
                timeout = setTimeout(func, wait);
            };
        };
        sliders.forEach(function(id) {
            var slider = document.getElementById(id);
            var valueSpan = document.getElementById(id + 'Value');
            if (!slider || !valueSpan) return;
            slider.addEventListener('input', debounce(function() {
                var value = parseFloat(this.value) || 50; // Default to 50 if NaN
                var key = id.replace(/^target/, '').replace(/^./, function(c) { return c.toLowerCase(); });
                window.sliderState[key] = value.toString();
                valueSpan.textContent = Math.round(value) + '% (' + value.toFixed(1) + '%)'; // Update value span
                fetchTargetProbabilityData(function() {
                    drawAllPlots();
                    updateResultsSummary();
                });
